# Jira — ticket management
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-api-token

# Slack — messaging
SLACK_TOKEN=xoxp-your-token

# GitLab — code & CI/CD
GITLAB_BASE_URL=https://gitlab.4players.de
GITLAB_TOKEN=your-gitlab-pat

# MariaDB — read-only database access (via tunnel)
DB_HOSTNAME=_
DB_USERNAME=_
DB_PASSWORD=_
DB_DATABASE=_

# Elasticsearch — gameserver log search
ELASTICSEARCH_API_URL=https://your-elk-host/_search-or-index
ELASTICSEARCH_API_KEY=your-api-key

# Loki (via Fleet Grafana) — Fleet container logs
FLEET_GRAFANA_URL=https://your-grafana-host
FLEET_GRAFANA_USERNAME=your-username
FLEET_GRAFANA_PASSWORD=your-password
